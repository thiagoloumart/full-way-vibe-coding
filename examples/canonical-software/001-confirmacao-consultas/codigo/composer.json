{
    "name": "canonical-001/confirmacao-consultas",
    "type": "project",
    "description": "Canônico D1 da skill full-way-vibe-coding — exemplo documental (não é projeto operacional).",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0",
        "livewire/livewire": "^3.0",
        "symfony/uid": "^7.0",
        "brick/phonenumber": "^0.6",
        "guzzlehttp/guzzle": "^7.8",
        "predis/predis": "^2.2"
    },
    "require-dev": {
        "laravel/breeze": "^2.0",
        "laravel/pint": "^1.20",
        "phpstan/phpstan": "^2.0",
        "pestphp/pest": "^3.5",
        "pestphp/pest-plugin-laravel": "^3.0",
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint --test",
        "lint:fix": "pint",
        "analyse": "phpstan analyse",
        "ci": [
            "@lint",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
