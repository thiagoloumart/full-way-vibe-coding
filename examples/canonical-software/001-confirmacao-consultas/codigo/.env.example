# Canônico 001 — env vars de exemplo.
# Ver plan.md §2.2 para descrição de cada variável.

APP_NAME=ConfirmacaoConsultas
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_MASK_PII=true

# ---------- Banco ----------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=confirmacao_consultas
DB_USERNAME=postgres
DB_PASSWORD=

# ---------- Cache / Fila ----------
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ---------- WhatsApp (C-004 · ADR-L-001) ----------
# Valores aceitos: meta (default), zapi, noop.
WHATSAPP_DRIVER=noop

# Meta Cloud API (usado se WHATSAPP_DRIVER=meta)
META_API_BASE_URL=https://graph.facebook.com/v19.0
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_WABA_ID=
META_WEBHOOK_VERIFY_TOKEN=
META_TEMPLATE_LEMBRETE_NAME=lembrete_consulta_utility_v1
META_TEMPLATE_LEMBRETE_LANG=pt_BR
META_TIMEOUT_SEGUNDOS=10

# Z-API (usado se WHATSAPP_DRIVER=zapi — plano de reversão ADR-L-001)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=

# ---------- Rate limit (DT-08) ----------
# Resolve [NEEDS CLARIFICATION] residual da constituição v1.0 §6.
NOTIFICACAO_RATE_LIMIT_POR_CLINICA_MINUTO=50

# ---------- Mail operacional (NÃO paciente) ----------
MAIL_MAILER=log
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="${APP_NAME}"
